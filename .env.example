# OAuth Broker example environment file.
# Copy this file to .env and replace all placeholder values before running in production.
# Do not commit your real .env file.

# Gin runtime mode. Use release in production.
GIN_MODE=release

# HTTP listen address for the Gin server.
LISTEN_ADDR=:8080

# Public HTTPS base URL of this broker.
# OAuth provider redirect URLs must use the same host and path.
PUBLIC_BASE_URL=https://oauth.example.com

# OAuth session lifetime. A NAS must finish the browser authorization before this expires.
SESSION_TTL=10m

# Interval for cleaning expired OAuth sessions and transient auth records.
SESSION_CLEANUP_INTERVAL=1m

# Application log file. Use an absolute path in production, for example:
# LOG_FILE=/var/log/oauth-broker/oauth-broker.log
LOG_FILE=logs/oauth-broker.log

# PostgreSQL connection string.
# Example for managed PostgreSQL: postgresql://user:password@host/db?sslmode=require
DATABASE_URL=postgresql://user:password@host/db?sslmode=require

# Secret used to sign broker-issued JWT access tokens.
# Generate a strong value, for example: openssl rand -base64 48
JWT_SECRET=replace-with-a-long-random-secret

# Broker JWT lifetime used by NAS clients when calling protected broker APIs.
JWT_ACCESS_TOKEN_TTL=15m

# JWT metadata. Keep these stable once clients are deployed.
JWT_ISSUER=yesnas-oauth-broker
JWT_AUDIENCE=yesnas-nas

# Optional registration secret for /api/devices/register.
# If empty, device registration is open. Set this in production.
DEVICE_REGISTRATION_SECRET=replace-with-registration-secret

# Maximum clock skew allowed for NAS signed auth requests.
DEVICE_SIGNATURE_CLOCK_SKEW=5m

# Google Drive OAuth app settings.
# Redirect URI in Google Cloud Console:
# https://oauth.example.com/api/oauth/google/callback
GOOGLE_CLIENT_ID=xxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxx
GOOGLE_REDIRECT_URL=https://oauth.example.com/api/oauth/google/callback
GOOGLE_SCOPES=https://www.googleapis.com/auth/drive

# Microsoft OneDrive OAuth app settings.
# Redirect URI in Azure App Registration:
# https://oauth.example.com/api/oauth/onedrive/callback
# offline_access is required for refresh tokens.
ONEDRIVE_CLIENT_ID=xxx
ONEDRIVE_CLIENT_SECRET=xxx
ONEDRIVE_REDIRECT_URL=https://oauth.example.com/api/oauth/onedrive/callback
ONEDRIVE_SCOPES=offline_access,Files.ReadWrite

# Dropbox OAuth app settings.
# Redirect URI in Dropbox App Console:
# https://oauth.example.com/api/oauth/dropbox/callback
DROPBOX_CLIENT_ID=xxx
DROPBOX_CLIENT_SECRET=xxx
DROPBOX_REDIRECT_URL=https://oauth.example.com/api/oauth/dropbox/callback
DROPBOX_SCOPES=files.metadata.read,files.metadata.write,files.content.read,files.content.write